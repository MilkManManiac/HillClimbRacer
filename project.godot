; Engine configuration file.
; "Car Game" (working title) — cosmic-horror road trip.
; Godot 4.6.x, Forward+ renderer.

config_version=5

[application]

config/name="Car Game"
config/description="Cosmic-horror road trip. Working title."
run/main_scene="res://scenes/HillClimb.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"

